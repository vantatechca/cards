# CardVault Environment Variables
# Copy this file to .env and fill in your values

# Backend API (your Render Web Service URL)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Claude API (for card identification, grading, recommendations)
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-your-key-here

# eBay API (for sold listings pricing)
EXPO_PUBLIC_EBAY_APP_ID=your-ebay-app-id

# TCGPlayer API (for MTG and Yu-Gi-Oh pricing)
EXPO_PUBLIC_TCGPLAYER_API_KEY=your-tcgplayer-key

# CardMarket API (for European pricing)
EXPO_PUBLIC_CARDMARKET_APP_TOKEN=your-cardmarket-token

# Set to 'false' to use real APIs instead of mock data
EXPO_PUBLIC_USE_MOCKS=true
